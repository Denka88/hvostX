# Включить перезапись URL
<IfModule mod_rewrite.c>
    RewriteEngine On
    RewriteBase /

    # НЕ перенаправлять существующие файлы и директории
    RewriteCond %{REQUEST_FILENAME} -f [OR]
    RewriteCond %{REQUEST_FILENAME} -d
    RewriteRule ^ - [L]

    # Исключения для системных файлов
    RewriteCond %{REQUEST_URI} ^/assets/ [OR]
    RewriteCond %{REQUEST_URI} ^/includes/ [OR]
    RewriteCond %{REQUEST_URI} ^/admin/ [OR]
    RewriteCond %{REQUEST_URI} ^/404\.php$ [OR]
    RewriteCond %{REQUEST_URI} ^/redirect\.php$
    RewriteRule ^ - [L]

    # Все остальные запросы -> redirect.php
    RewriteRule ^(.*)$ redirect.php [L,QSA]
</IfModule>

# Статические редиректы (быстрые, без БД)
# Redirect 301 /old-page.php /new-page.php

# Защита директорий
Options -Indexes

# Кэширование
<IfModule mod_expires.c>
    ExpiresActive On
    ExpiresByType image/jpg "access plus 1 year"
    ExpiresByType image/jpeg "access plus 1 year"
    ExpiresByType image/gif "access plus 1 year"
    ExpiresByType image/png "access plus 1 year"
    ExpiresByType text/css "access plus 1 month"
    ExpiresByType application/javascript "access plus 1 month"
</IfModule>

# GZIP сжатие
<IfModule mod_deflate.c>
    AddOutputFilterByType DEFLATE text/html text/css application/javascript
</IfModule>
